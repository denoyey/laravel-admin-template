{
    "name": "denoyey/laravel-admin-template",
    "description": "A clean, modern, and OOP-based Admin Dashboard and Auth starter kit for Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "denoyey"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/console": "^12.0",
        "illuminate/filesystem": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Denoyey\\AdminTemplate\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Denoyey\\AdminTemplate\\AdminTemplateServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}